<resources>
    <style name="Theme.WmTippspiel" parent="android:style/Theme.Material.Light.NoActionBar">
        <item name="android:fontFamily">sans</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:statusBarColor">#F7F8FC</item>
        <item name="android:navigationBarColor">#F7F8FC</item>
    </style>
    <style name="Theme.WmTippspiel.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">#F7F8FC</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/oesterfeld_logo_round</item>
        <item name="postSplashScreenTheme">@style/Theme.WmTippspiel</item>
    </style>
</resources>
